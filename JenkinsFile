pipeline {

    agent any

    tools {

        maven 'Maven 3.x' 

        jdk 'Java 21' 

    }
 
    stages {

        stage('Checkout') {

            steps {

                checkout scm 

            }

        }
 
        stage('Build') {

            steps {

                sh 'mvn clean package -DskipTests'  

            }

        }
 
        

    }

}
 