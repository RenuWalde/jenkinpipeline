pipeline {

    agent any

    tools {

        maven 'Maven 3.x' 

        jdk 'Java 17' 

    }
 
    stages {

        stage('Checkout') {

            steps {

                checkout scm 

            }

        }
 
        stage('Build') {

            steps {

                bat 'mvn clean package -DskipTests'  

            }

        }
 
        stage('Test') {

            steps {

                bat 'mvn test' 

            }

        }
 
        stage('Artifact Archiving') {

            steps {

                archiveArtifacts artifacts: 'target/*.jar', fingerprint: true

            }

        }

    }

}
 
