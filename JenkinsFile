pipeline {
    agent any
    
    tools {
        maven 'Maven 3.x' 
        jdk 'Java 17' 
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm 
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean package -DskipTests'  
            }
        }

      
    }
}
